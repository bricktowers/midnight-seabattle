{
  "packageManager": "yarn@4.9.2",
  "workspaces": [
    "compact",
    "battleship-api",
    "battleship-indexer",
    "battleship-ui",
    "battleship-west-contract",
    "battleship-east-contract",
    "token-contract"
  ],
  "scripts": {
    "compact": "turbo run compact",
    "build": "turbo run build",
    "test": "turbo run test",
    "test-e2e": "turbo run test-e2e",
    "lint": "turbo run lint",
    "battleship-ui": "turbo run start --filter=battleship-ui",
    "test-full-game": "yarn workspace @bricktowers/battleship-api vitest run -t \"should simulate full game\"",
    "postinstall": "npx patch-package"
  },
  "resolutions": {
    "@midnight-ntwrk/ledger-v8": "8.0.3",
    "effect": "3.21.0"
  },
  "dependencies": {
